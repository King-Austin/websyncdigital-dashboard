# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@yourapp.com
RESEND_FROM_NAME=Your App

# Paystack
# Use sk_test_… / pk_test_… for development, sk_live_… / pk_live_… for production.
# Create a plan at: Paystack Dashboard → Products → Plans (₦9,999/month)
# Register your webhook: Paystack Dashboard → Settings → API Keys & Webhooks
#   Webhook URL: https://yourdomain.com/api/webhooks/paystack
PAYSTACK_SECRET_KEY=sk_test_…
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_…
NEXT_PUBLIC_PAYSTACK_SHOP_LINK=https://paystack.shop/pay/…
NEXT_PUBLIC_PAYSTACK_PLAN_CODE=PLN_…

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
WS_TEAM_EMAIL=team@yourapp.com

# Google PageSpeed Insights (optional — works without key, rate-limited)
PAGESPEED_API_KEY=

# Admin registration gate
ADMIN_SIGNUP_CODE=change-me-before-deploy
